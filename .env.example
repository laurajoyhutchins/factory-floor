# Local development defaults only. Do not use these credentials in production.
DATABASE_URL=postgres://factory_floor:factory_floor_dev_password@127.0.0.1:5432/factory_floor
TEST_DATABASE_URL=postgres://factory_floor:factory_floor_dev_password@127.0.0.1:5432/factory_floor
POSTGRES_DB=factory_floor
POSTGRES_USER=factory_floor
POSTGRES_PASSWORD=factory_floor_dev_password

MINIO_ROOT_USER=factoryfloor
MINIO_ROOT_PASSWORD=factoryfloor_dev_password
FACTORY_FLOOR_MINIO_ENDPOINT=http://127.0.0.1:9000
FACTORY_FLOOR_MINIO_BUCKET=factory-floor-dev

# Ports are bound to loopback by default. Override only for trusted local development.
FACTORY_FLOOR_POSTGRES_BIND=127.0.0.1
FACTORY_FLOOR_POSTGRES_PORT=5432
FACTORY_FLOOR_MINIO_BIND=127.0.0.1
FACTORY_FLOOR_MINIO_API_PORT=9000
FACTORY_FLOOR_MINIO_CONSOLE_PORT=9001
HOST=127.0.0.1

# The actual server fails closed unless these distinct tokens are configured.
CONTROL_PLANE_OPERATOR_TOKEN=factory_floor_local_operator_token
CONTROL_PLANE_ADMIN_TOKEN=factory_floor_local_admin_token

# The server advertises this URL in worker invocation envelopes.
FACTORY_FLOOR_CONTROL_PLANE_URL=http://127.0.0.1:3000
# Worker SDKs connect to this URL.
FACTORY_FLOOR_WORKER_BASE_URL=http://127.0.0.1:3000
# Keep the server and worker values identical for local development.
WORKER_API_BEARER_TOKEN=factory_floor_local_worker_token
FACTORY_FLOOR_WORKER_TOKEN=factory_floor_local_worker_token
FACTORY_FLOOR_WORKER_ID=demo-worker
ARTIFACT_STORE_ROOT=.factory-floor/artifacts

# Operator console dev proxy target and read-only bearer token.
# The Vite server remains bound to 127.0.0.1 by default.
FACTORY_FLOOR_CONSOLE_CONTROL_PLANE_URL=http://127.0.0.1:3000
VITE_FACTORY_FLOOR_OPERATOR_TOKEN=factory_floor_local_operator_token
