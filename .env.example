# Disposable local-development values only. Replace every `change_me_...` value
# before use, never reuse these values in another environment, and never commit
# a populated .env file.
DATABASE_URL=postgres://factory_floor:change_me_local_postgres_password@127.0.0.1:5432/factory_floor
TEST_DATABASE_URL=postgres://factory_floor:change_me_local_postgres_password@127.0.0.1:5432/factory_floor
POSTGRES_DB=factory_floor
POSTGRES_USER=factory_floor
POSTGRES_PASSWORD=change_me_local_postgres_password

MINIO_ROOT_USER=factoryfloor
MINIO_ROOT_PASSWORD=change_me_local_minio_password
FACTORY_FLOOR_MINIO_ENDPOINT=http://127.0.0.1:9000
FACTORY_FLOOR_MINIO_BUCKET=factory-floor-dev

# Ports are bound to loopback by default. Override only for trusted local development.
FACTORY_FLOOR_POSTGRES_BIND=127.0.0.1
FACTORY_FLOOR_POSTGRES_PORT=5432
FACTORY_FLOOR_MINIO_BIND=127.0.0.1
FACTORY_FLOOR_MINIO_API_PORT=9000
FACTORY_FLOOR_MINIO_CONSOLE_PORT=9001
HOST=127.0.0.1

# The actual server fails closed unless these distinct tokens are configured.
CONTROL_PLANE_OPERATOR_TOKEN=change_me_local_operator_token
CONTROL_PLANE_ADMIN_TOKEN=change_me_local_admin_token

# The server advertises this URL in worker invocation envelopes.
FACTORY_FLOOR_CONTROL_PLANE_URL=http://127.0.0.1:3000
# Worker SDKs connect to this URL.
FACTORY_FLOOR_WORKER_BASE_URL=http://127.0.0.1:3000
# Worker clients use this disposable local-development credential.
WORKER_API_BEARER_TOKEN=change_me_local_worker_token
FACTORY_FLOOR_WORKER_TOKEN=change_me_local_worker_token
FACTORY_FLOOR_WORKER_ID=demo-worker
FACTORY_FLOOR_WORKER_COMPONENT_SELECTORS=retrieve@1,compare@1,synthesize@1,verify@1
# Deprecated compatibility alias: FACTORY_FLOOR_WORKER_CAPABILITIES=retrieve@1,compare@1,synthesize@1,verify@1
# The control plane binds that credential to explicit local worker identities and selectors.
WORKER_AUTHORIZATION_JSON='{"demo-worker":{"token":"change_me_local_worker_token","componentSelectors":["retrieve@1","compare@1","synthesize@1","verify@1"]},"demo-ts-worker":{"token":"change_me_local_worker_token","componentSelectors":["retrieve@1","compare@1","synthesize@1"]},"demo-py-worker":{"token":"change_me_local_worker_token","componentSelectors":["verify@1"]},"acceptance-ts-worker":{"token":"change_me_local_worker_token","componentSelectors":["retrieve@1","compare@1","synthesize@1"]},"acceptance-py-worker":{"token":"change_me_local_worker_token","componentSelectors":["verify@1"]}}'
ARTIFACT_STORE_ROOT=.factory-floor/artifacts

# Operator console dev proxy target and read-only bearer token.
# The Vite server remains bound to 127.0.0.1 by default.
FACTORY_FLOOR_CONSOLE_CONTROL_PLANE_URL=http://127.0.0.1:3000
VITE_FACTORY_FLOOR_OPERATOR_TOKEN=change_me_local_operator_token