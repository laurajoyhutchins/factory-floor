# Local development defaults only. Do not commit a populated .env or real secrets.
NODE_ENV=development
PORT=3000
HOST=127.0.0.1
DATABASE_URL=postgres://factory_floor:factory_floor_dev_password@127.0.0.1:5432/factory_floor
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=factoryfloor
MINIO_SECRET_KEY=factoryfloor_dev_password
MINIO_BUCKET=factory-floor-artifacts
ARTIFACT_STORE_ROOT=.factory-floor/artifacts

# Worker HTTP protocol local-only credentials. Replace outside local development.
WORKER_API_BEARER_TOKEN=local-worker-token-do-not-use-in-production
WORKER_LEASE_DURATION_MS=60000
CONTROL_PLANE_PUBLIC_URL=http://127.0.0.1:3000
