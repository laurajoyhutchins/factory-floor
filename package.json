{
  "name": "factory-floor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev:services": "docker compose up -d postgres minio",
    "dev:control-plane": "pnpm --filter @factory-floor/control-plane dev",
    "contracts:validate": "node scripts/validate-contracts.mjs",
    "contracts:generate": "node scripts/generate-contracts.mjs",
    "contracts:check": "bash scripts/check-contract-generation-drift.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.15.34",
    "@types/pg": "^8.20.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.30.1",
    "json-schema-to-typescript": "^15.0.4",
    "pg": "^8.22.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
