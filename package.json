{
  "name": "factory-floor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts && pnpm demo:investigation",
    "dev:services": "docker compose up -d postgres minio",
    "dev:control-plane": "pnpm --filter @factory-floor/control-plane dev",
    "contracts:validate": "node scripts/validate-contracts.mjs",
    "contracts:generate": "node scripts/generate-contracts.mjs",
    "contracts:check": "bash scripts/check-contract-generation-drift.sh",
    "dev:worker-demo-ts": "pnpm --filter @factory-floor/demo-ts-worker dev",
    "demo:investigation": "tsx examples/investigation/run-demo.ts",
    "bootstrap": "bash scripts/bootstrap-workspace.sh",
    "services:up": "docker compose up -d postgres minio",
    "services:wait": "bash scripts/wait-for-services.sh postgres minio",
    "services:status": "docker compose ps",
    "services:logs": "docker compose logs --no-color --tail=120 postgres minio",
    "services:down": "docker compose down",
    "services:clean": "docker compose down --volumes --remove-orphans",
    "db:migrate": "pnpm --filter @factory-floor/db migrate up",
    "db:reset": "NODE_ENV=development pnpm --filter @factory-floor/db migrate reset",
    "dev:worker-demo-py": "uv run --project workers/demo-py --locked factory-floor-demo-py",
    "dev:workers": "node scripts/run-dev-processes.mjs",
    "test:python": "uv run --project packages/worker-sdk-py --locked pytest && uv run --project workers/demo-py --locked pytest",
    "test:conformance": "vitest run --config vitest.integration.config.ts tests/integration/runtime-core/observability-recovery.test.ts",
    "verify": "pnpm contracts:validate && pnpm contracts:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:python && docker compose config && pnpm test:integration && pnpm test:conformance",
    "format:check": "prettier --check .",
    "artifacts:reconcile": "pnpm --filter @factory-floor/control-plane artifacts:reconcile",
    "projections:rebuild": "tsx scripts/rebuild-projections.mjs",
    "cleanup": "bash scripts/maintain-workspace.sh clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.15.34",
    "@types/pg": "^8.20.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.30.1",
    "json-schema-to-typescript": "^15.0.4",
    "pg": "^8.22.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
