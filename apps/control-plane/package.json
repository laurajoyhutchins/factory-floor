{
  "name": "@factory-floor/control-plane",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/app.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.build.json --pretty false --force",
    "start": "node dist/server.js",
    "dev": "node ../../scripts/run-package-entrypoint.mjs tsx watch src/server.ts -- node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "test": "vitest run --root ../.. apps/control-plane",
    "artifacts:reconcile": "tsx src/maintenance/artifacts-reconcile.ts --dry-run"
  },
  "dependencies": {
    "fastify": "^5.4.0",
    "@factory-floor/db": "workspace:*",
    "@factory-floor/runtime-core": "workspace:*",
    "yaml": "^2.9.0",
    "kysely": "^0.29.3",
    "@factory-floor/artifact-store": "workspace:*"
  }
}
