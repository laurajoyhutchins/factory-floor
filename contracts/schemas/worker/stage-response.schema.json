{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-floor.local/contracts/worker/stage-response.schema.json",
  "title": "WorkerStageResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocolVersion": { "const": "1.0" },
    "stagedRef": { "type": "string", "minLength": 1 },
    "uploadUrl": { "type": "string", "format": "uri-reference" },
    "expiresAt": { "type": "string", "format": "date-time" }
  },
  "required": ["protocolVersion", "stagedRef", "uploadUrl", "expiresAt"]
}
