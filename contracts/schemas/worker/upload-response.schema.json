{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-floor.local/contracts/worker/upload-response.schema.json",
  "title": "WorkerUploadResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocolVersion": { "const": "1.0" },
    "stagedRef": { "type": "string" },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sizeBytes": { "type": "integer", "minimum": 0 }
  },
  "required": ["protocolVersion", "stagedRef", "digest", "sizeBytes"]
}
