{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-floor.local/contracts/worker/stage-request.schema.json",
  "title": "WorkerStageRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocolVersion": { "const": "1.0" },
    "executionId": { "type": "string", "format": "uuid" },
    "attemptId": { "type": "string", "format": "uuid" },
    "leaseToken": { "type": "string", "minLength": 1 },
    "lifecycleEpoch": { "type": "integer", "minimum": 0 },
    "portName": { "type": "string", "minLength": 1, "maxLength": 128 },
    "mediaType": { "type": "string", "minLength": 1, "maxLength": 255 },
    "expectedDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "expectedSizeBytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 104857600
    },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "required": [
    "protocolVersion",
    "executionId",
    "attemptId",
    "leaseToken",
    "lifecycleEpoch",
    "portName",
    "mediaType",
    "expectedDigest",
    "expectedSizeBytes",
    "metadata"
  ]
}
