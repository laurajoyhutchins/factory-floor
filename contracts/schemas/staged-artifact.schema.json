{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-floor.local/contracts/staged-artifact.schema.json",
  "title": "StagedArtifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "stagingId": { "type": "string", "format": "uuid" },
    "portName": { "type": "string", "minLength": 1 },
    "digest": { "$ref": "artifact-descriptor.schema.json#/$defs/sha256Digest" },
    "sizeBytes": { "type": "integer", "minimum": 0 },
    "mediaType": { "type": "string", "minLength": 1 },
    "schemaId": { "type": "string", "minLength": 1 },
    "schemaDigest": {
      "$ref": "artifact-descriptor.schema.json#/$defs/sha256Digest"
    },
    "provenance": { "$ref": "source-identity.schema.json" }
  },
  "required": [
    "stagingId",
    "portName",
    "digest",
    "sizeBytes",
    "mediaType",
    "schemaId",
    "schemaDigest",
    "provenance"
  ]
}
