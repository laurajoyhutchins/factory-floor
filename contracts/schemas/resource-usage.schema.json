{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-floor.local/contracts/resource-usage.schema.json",
  "title": "ResourceUsage",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "cpuMilliseconds": { "type": "integer", "minimum": 0 },
    "wallMilliseconds": { "type": "integer", "minimum": 0 },
    "inputBytes": { "type": "integer", "minimum": 0 },
    "outputBytes": { "type": "integer", "minimum": 0 },
    "externalCalls": { "type": "integer", "minimum": 0 }
  },
  "required": ["cpuMilliseconds", "wallMilliseconds", "inputBytes", "outputBytes", "externalCalls"]
}
