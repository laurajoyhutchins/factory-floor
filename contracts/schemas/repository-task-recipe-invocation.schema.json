{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-floor.local/contracts/repository-task-recipe-invocation.schema.json",
  "title": "RepositoryTaskRecipeInvocation",
  "description": "A versioned deterministic recipe selection and its bounded inputs. Recipe resolution remains repository-owned.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*$"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "required": ["name", "version", "inputs"]
}
