{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-floor.local/contracts/repository-task-normalized-plan.schema.json",
  "title": "RepositoryTaskNormalizedPlan",
  "description": "Canonical replayable state derived from authored repository-task intent. The digest covers this object without planDigest and does not represent a policy grant.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string", "minLength": 1, "maxLength": 39 },
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "baseRevision": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        }
      },
      "required": ["owner", "name", "baseRevision"]
    },
    "resourceBounds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxFiles": { "type": "integer", "minimum": 1, "maximum": 100 },
        "maxPatchBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10485760
        },
        "maxVerificationSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        }
      },
      "required": ["maxFiles", "maxPatchBytes", "maxVerificationSeconds"]
    }
  },
  "properties": {
    "schemaVersion": { "const": 1 },
    "objective": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "repository": { "$ref": "#/$defs/repository" },
    "allowedPaths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "recipe": {
      "$ref": "repository-task-recipe-invocation.schema.json"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "repository-task-declared-output.schema.json"
      }
    },
    "verificationProfile": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "resourceBounds": { "$ref": "#/$defs/resourceBounds" },
    "requestedCapabilities": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-zA-Z0-9]*(\\.[a-z][a-zA-Z0-9]*)+$"
      }
    },
    "completionCriteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "planDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "required": [
    "schemaVersion",
    "objective",
    "repository",
    "allowedPaths",
    "recipe",
    "outputs",
    "verificationProfile",
    "resourceBounds",
    "requestedCapabilities",
    "completionCriteria",
    "planDigest"
  ]
}
